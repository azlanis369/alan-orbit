# Super Ren Group — Environment Variables
# Salin fail ini ke `.env.local` dan isi nilai dari projek Supabase anda.

# Supabase project URL, cth: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (selamat didedahkan ke client kerana RLS aktif)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — RAHSIA. Server-only. Jangan dedah ke client.
SUPABASE_SERVICE_ROLE_KEY=

# URL awam aplikasi (untuk Open Graph & share link), cth: https://superren.group
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nama bucket Supabase Storage untuk media listing
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=listing-media
